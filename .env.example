# 0G Compute Router (OpenAI-compatible) API key. The Router is billed
# against a MAINNET 0G balance (pc.0g.ai). Used when no VITE_AI_* fallback
# is set below.
VITE_OG_COMPUTE_API_KEY=sk-your-key-here

# Optional OpenAI-compatible fallback provider (Anthropic, OpenAI, etc.).
# When VITE_AI_BASE_URL is set it overrides the 0G Router for chat — use
# this for testnet/hackathon builds without a funded mainnet Router
# balance. To run natively on 0G Compute, leave these blank (or set
# VITE_AI_BASE_URL=https://router-api.0g.ai/v1 and VITE_AI_MODEL=glm-5).
VITE_AI_BASE_URL=
VITE_AI_API_KEY=
VITE_AI_MODEL=

# Optional same-provider fallback model. Groq rate-limits PER MODEL, so when the
# primary VITE_AI_MODEL hits its tokens-per-minute cap (even after backoff), the
# agent retries the same request on this model — a separate rate-limit bucket,
# same key and endpoint. Must be tool-call capable. Leave blank to disable.
# On Groq, llama-3.3-70b-versatile (12k TPM) pairs well with gpt-oss-120b (8k).
VITE_AI_FALLBACK_MODEL=

# ─────────────────────────────────────────────────────────────────────
# 0G STORAGE.
#
# PRODUCTION (Vercel): sync runs through the /api/og-sync serverless
# function (the testnet storage nodes are HTTP-only and a browser blocks
# them from an HTTPS page). Set these SERVER-SIDE vars in Vercel project
# settings (no VITE_ prefix → not in the client bundle):
#   OG_PRIVATE_KEY=0xyour-testnet-key
#   OG_RPC_URL=https://evmrpc-testnet.0g.ai
#   OG_INDEXER_URL=https://indexer-storage-testnet-turbo.0g.ai
#
# LOCAL DEV (http://localhost): the browser runs the SDK directly, so it
# needs the VITE_ versions below.

# Testnet wallet private key used to sign 0G Storage uploads (local dev).
# Throwaway testnet key only — exposed in the dev client bundle.
VITE_OG_PRIVATE_KEY=your-testnet-wallet-key

# 0G Galileo testnet (local dev)
VITE_OG_RPC_URL=https://evmrpc-testnet.0g.ai
VITE_OG_INDEXER_URL=https://indexer-storage-testnet-turbo.0g.ai

