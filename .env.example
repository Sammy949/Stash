# 0G Compute Router (OpenAI-compatible) API key
VITE_OG_COMPUTE_API_KEY=sk-your-key-here

# Testnet wallet private key used to sign 0G Storage uploads.
# WARNING: this is exposed in the browser bundle — use a throwaway
# testnet key with minimal funds only. See README security note.
VITE_OG_PRIVATE_KEY=your-testnet-wallet-key

# 0G Galileo testnet
VITE_OG_RPC_URL=https://evmrpc-testnet.0g.ai
VITE_OG_INDEXER_URL=https://indexer-storage-testnet-turbo.0g.ai
